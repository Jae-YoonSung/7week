--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 157eaca233ea8054cbb544d6601ccdea, type: 3}
  m_Name: TutorialGuideData
  m_EditorClassIdentifier: Assembly-CSharp::TutorialGuideData
  PhaseGuides:
  - Phase: 1
    GuideText: "\uC774\uACF3\uC740 \uC6A9\uC758\uC790\uB4E4\uC774 \uC788\uB294 \uB9C8\uC744\uC785\uB2C8\uB2E4.\\n\uBE5B\uB098\uB294
      \uC778\uBB3C\uC744 \uC8FC\uBAA9\uD558\uC138\uC694.\r\n"
  - Phase: 2
    GuideText: "\uD45C\uC2DC\uB41C \uC778\uBB3C\uC744 \uB4DC\uB798\uADF8\uD574\\n\uBE5B\uB098\uB294
      \uAD6C\uC5ED\uC73C\uB85C \uC774\uB3D9\uC2DC\uCF1C \uBCF4\uC138\uC694.\r\n"
  - Phase: 3
    GuideText: "\uC798 \uD558\uC168\uC2B5\uB2C8\uB2E4!\\n\uC774\uC81C \uAE43\uD138\uD39C\uC744
      \uAFB9 \uB20C\uB7EC \uD558\uB8E8\uB97C \uB118\uACA8\uBCF4\uC138\uC694.\r\n"
  - Phase: 5
    GuideText: "\uC624\uB298 \uD558\uB8E8 \uC77C\uC5B4\uB09C \uC77C\uB4E4\uC785\uB2C8\uB2E4.\\n\uB0B4\uC6A9\uC744
      \uC798 \uAE30\uC5B5\uD574 \uB450\uC138\uC694.\r\n"
  - Phase: 6
    GuideText: "\uC5ED\uD560 \uAE30\uB2A5 \uD328\uB110\uC744 \uC5F4\uC5B4\\n\uAC01
      \uC5ED\uD560\uC758 \uB2A5\uB825\uC744 \uD655\uC778\uD574 \uBCF4\uC138\uC694."
  - Phase: 7
    GuideText: "\uC0AC\uC11C\uC21C \uD328\uB110\uC5D0\uC11C\\n\uC774\uC57C\uAE30
      \uC804\uAC1C \uC21C\uC11C\uB97C \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\r\n"
  - Phase: 8
    GuideText: "\uBA54\uBAA8 \uC218\uCCA9\uC744 \uC5F4\uC5B4\\n\uC6A9\uC758\uC790\uB97C
      \uC815\uB9AC\uD574 \uBCF4\uC138\uC694."
  - Phase: 10
    GuideText: "\uC6A9\uC758\uC790 \uC606 \uAE30\uD638\uB97C \uB20C\uB7EC\\nO / \u25B3
      / X \uB85C \uC758\uC2EC\uB3C4\uB97C \uD45C\uC2DC\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - Phase: 9
    GuideText: "\uC0AC\uAC74 \uAE30\uB85D \uD3EC\uC2A4\uD2B8\uC787\uC744 \uB20C\uB7EC\\n\uC9C0\uB09C
      \uC0AC\uAC74\uC744 \uB2E4\uC2DC \uD655\uC778\uD558\uC138\uC694."
  - Phase: 11
    GuideText: "\uBE5B\uB098\uB294 \uCC45\uC744 \uAFB9 \uB204\uB974\uBA74\\n\uCD5C\uC885
      \uC9D1\uD544 \uB2E8\uACC4\uB85C \uC9C4\uC785\uD569\uB2C8\uB2E4."
  - Phase: 12
    GuideText: "\uC0C1\uB2E8\uC758 \uB0A0\uC9DC\uB97C \uD655\uC778\uD558\uC138\uC694.\\n\uB9C8\uAC10\uC77C
      \uC804\uC5D0 \uBC94\uC778\uC744 \uBC1D\uD600\uB0B4\uC57C \uD569\uB2C8\uB2E4."
  EventGuides:
  - EventType: 0
    GuideText: "\uD558\uB8E8\uAC00 \uC9C0\uB098 \uC6D0\uC810\uC73C\uB85C \uB3CC\uC544\uC654\uC2B5\uB2C8\uB2E4.\\n\uC0C8\uB85C\uC6B4
      \uC2DC\uAC01\uC73C\uB85C \uB2E4\uC2DC \uAD00\uCC30\uD574 \uBCF4\uC138\uC694."
  - EventType: 1
    GuideText: "\uC0AC\uAC74\uC774 \uB9C8\uBB34\uB9AC\uB418\uC5B4 \uC6D0\uC810\uC73C\uB85C
      \uB3CC\uC544\uC654\uC2B5\uB2C8\uB2E4.\\n\uC774 \uC815\uBCF4\uB97C \uB2E8\uC11C\uB85C
      \uD65C\uC6A9\uD558\uC138\uC694."
  - EventType: 2
    GuideText: "\uB9C8\uAC10\uC77C\uC774 \uB0B4\uC77C\uB85C \uB2E4\uAC00\uC654\uC2B5\uB2C8\uB2E4.\\n\uC624\uB298
      \uC548\uC5D0 \uBC94\uC778\uC744 \uD2B9\uC815\uD574\uC57C \uD569\uB2C8\uB2E4!"
  - EventType: 3
    GuideText: "\uCD5C\uC885 \uC9D1\uD544\uC785\uB2C8\uB2E4.\\n\uC5ED\uD560 \uCE74\uB4DC\uB97C
      \uC62C\uBC14\uB978 \uCE78\uC5D0 \uBC30\uCE58\uD558\uC138\uC694."
  - EventType: 4
    GuideText: "\uCD94\uB9AC\uAC00 \uD2C0\uB838\uC2B5\uB2C8\uB2E4.\\n\uCC98\uC74C\uBD80\uD130
      \uB2E4\uC2DC \uB3C4\uC804\uD574 \uBCF4\uC138\uC694."
