  m_Script: {fileID: 11500000, guid: 5f4571b09e5e8f949ba82771c4a93aa2, type: 3}
  m_Name: Ending
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  lines:
  - "\uB098\uB294\u2026\u2026,\r\n\r\n\uB098\uB294 \uACB0\uAD6D \uC368 \uBC84\uB838\uC18C.\r\n\r\n\uC774\uD1A0\uB85D
    \uC26C\uC774 \uB05D\uB0BC \uC218 \uC788\uB358 \uC77C\uC744, \uC774\uC81C\uC57C
    \uB9C8\uBB34\uB9AC\uD55C \uB098\uB97C \uC6A9\uC11C\uD558\uC2DC\uC624.\r\n\r\n\uB2F9\uC2E0\uC758
    \uC18C\uC124\uC774 \uB05D\uC744 \uB9FA\uB294\uB2E4\uBA74, \uC5D0\uB4DC\uBA3C\uB4DC\uB77C\uB294
    \uC778\uBB3C\uB3C4 \uBAA8\uB450\uC758 \uAE30\uC5B5 \uC18D\uC5D0\uC11C \uB05D\uC744
    \uB9FA\uC744\uAE4C \uB450\uB824\uC6E0\uC18C. \r\n\uC544\uB9C8 \uB098\uB294 \uB9C8\uC74C
    \uD55C \uAD6C\uC11D\uC5D0\uC11C, \uB2F9\uC2E0\uC758 \uC8FD\uC74C\uC774 \uC601\uC6D0\uD788
    \uBBF8\uACB0\uB85C \uB0A8\uAE30\uB97C \uBC14\uB790\uB358 \uBAA8\uC591\uC774\uC624.\r\n\r\n\uADF8\uB9AC\uC6B4
    \uC5D0\uB4DC\uBA3C\uB4DC.\r\n\uB098\uB3C4 \uC774\uC81C \uB2F9\uC2E0\uC758 \uBD80\uC7AC\uB97C
    \uC778\uC815\uD558\uB824 \uD558\uC624.\r\n\r\n\uB2F9\uC2E0\uC758 \uC18C\uC124\uC744
    \uB9C8\uBB34\uB9AC\uD558\uB294 \uB3D9\uC548, \uB9C8\uCE58 \uD568\uAED8 \uAE00\uC744
    \uC4F0\uB294 \uAE30\uBD84\uC774 \uB4E4\uC5C8\uC18C.\r\n\uACE0\uB9D9\uC18C.\r\n\r\n-\uB85C\uB80C\uC2A4"
