  m_Script: {fileID: 11500000, guid: 5f4571b09e5e8f949ba82771c4a93aa2, type: 3}
  m_Name: Title
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  lines:
  - "\uB85C\uB80C\uC2A4 \uC120\uC0DD\uAED8.\r\n\r\n\uC5D0\uB4DC\uBA3C\uB4DC \uC791\uAC00\uAED8\uC11C
    \uC138\uC0C1\uC744 \uB5A0\uB098\uC2E0 \uC9C0, \uC624\uB298\uB85C \uD55C \uD574\uAC00
    \uB418\uC5C8\uC2B5\uB2C8\uB2E4.\r\n\uC774\uBBF8 \uC5EC\uB7EC \uCC28\uB840 \uCCAD\uC744
    \uB4DC\uB9AC\uACE0\uB3C4, \uB2E4\uC2DC\uAE08 \uAE00\uC744 \uC62C\uB9AC\uB294
    \uBB34\uB840\uB97C \uC6A9\uC11C\uD574 \uC8FC\uC2DC\uAE30 \uBC14\uB78D\uB2C8\uB2E4.\r\n\uBBF8\uC644\uC758
    \uC6D0\uACE0\uB97C \uB05D\uB9FA\uC744 \uC218 \uC788\uB294 \uC0AC\uB78C\uC740,
    \uADF8\uC758 \uBC97\uC774\uC168\uB358 \uC120\uC0DD\uBFD0\uC785\uB2C8\uB2E4.\r\n\uBD80\uB514
    \uADF8 \uB9C8\uC9C0\uB9C9 \uC774\uC57C\uAE30\uB97C \uC368 \uC8FC\uC2DC\uAE30\uB97C
    \uCCAD\uD569\uB2C8\uB2E4.\r\n\r\n-\uC708\uD130\uD544\uB4DC \uC778\uC1C4\uC18C"
  - "\uADF8\uB9AC\uC6B4 \uC5D0\uB4DC\uBA3C\uB4DC. \uB85C\uB80C\uC2A4\uC694.\r\n\r\n\uC774
    \uD3B8\uC9C0\uAC00 \uB2FF\uC9C0 \uBABB\uD560 \uAC83\uCBE4\uC740 \uC54C\uACE0
    \uC788\uC18C. \uADF8\uC800\u2026 \uD478\uB150\uC744 \uB298\uC5B4\uB193\uACE0
    \uC2F6\uC5C8\uC744 \uBFD0\uC774\uC624.\r\n\uC624\uB298 \uC778\uC1C4\uC18C\uC758
    \uB300\uD544 \uC694\uCCAD\uC744 \uB2E4\uC2DC \uBC1B\uC558\uC18C.\r\n\uACE4\uD639\uC2A4\uB7FD\uB354\uAD70\u2026\r\n\r\n\uB9CC\uC57D
    \uB2F9\uC2E0\uC774 \uB098\uC600\uB2E4\uBA74, \uC5B4\uB5BB\uAC8C \uD558\uACA0\uC18C?\r\n\uB098\uB294\u2026\u2026"
